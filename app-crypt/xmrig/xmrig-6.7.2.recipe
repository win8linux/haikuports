SUMMARY="CPU-based cryptocurrency miner for Monero and others"
DESCRIPTION="XMRig is a high-performance, open-source, and \
cross-platform CPU miner for cryptocurrencies like Monero \
and as a RandomX benchmark.

It can use the RandomX, KawPow, Cryptonight, and AstroBWT Proof-of-Work \
algorithms. Additionally, it has a HTTP API for remote management and \
SSL/TLS support."
HOMEPAGE="https://xmrig.com/"
COPYRIGHT="2017-2020 XMRig developers"
LICENSE="GNU GPL v3"
REVISION="1"
srcGitTag="v6.7.2"
SOURCE_URI="https://github.com/xmrig/xmrig/archive/$srcGitTag.tar.gz"
CHECKSUM_SHA256="c843f6639a05893fd02c81319542c919e39871496c52c366f1cad879fb5393ec"
SOURCE_FILENAME="xmrig-$srcGitTag.tar.gz"
SOURCE_DIR="xmrig-$portVersion"

ARCHITECTURES="!x86_gcc2 x86_64"
SECONDARY_ARCHITECTURES="!x86"

PROVIDES="
	xmrig$secondaryArchSuffix = $portVersion
	cmd:xmrig$secondaryArchSuffix = $portVersion
	"
REQUIRES="
	haiku$secondaryArchSuffix
	lib:libuv$secondaryArchSuffix
	lib:hwloc$secondaryArchSuffix
	"
BUILD_REQUIRES="
	haiku${secondaryArchSuffix}_devel
	devel:libcrypto$secondaryArchSuffix
	devel:libuv$secondaryArchSuffix
	devel:hwloc$secondaryArchSuffix
	"
BUILD_PREREQUIRES="
	cmd:cmake
	cmd:g++$secondaryArchSuffix
	cmd:make
	"

BUILD()
{
	mkdir xmrig/build && cd xmrig/build
	cmake -DWITH_OPENCL=OFF -DWITH_CUDA=OFF ..
	make -j
}

INSTALL()
{
	mkdir -p $appsDir
	mv ./xmrig/build/xmrig $appsDir/xmrig
}
